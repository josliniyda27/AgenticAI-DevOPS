# ─────────────────────────────────────────────────────────────
#  RENAME THIS FILE:   env.sample  →  .env      (or just: env)
#  macOS/Linux:        cp env.sample .env
#  Windows (cmd):      copy env.sample .env
#  Then paste your own OpenAI API key below.
#  NEVER commit your real key — .env/env are git-ignored.
# ─────────────────────────────────────────────────────────────

OPENAI_API_KEY=sk-paste-your-key-here

# Models used by the code (defaults are fine — change only if you want)
MODEL=gpt-4o
MODEL_FAST=gpt-4o-mini
